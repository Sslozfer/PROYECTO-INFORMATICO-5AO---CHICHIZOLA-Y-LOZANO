# Database
# Si usás `docker compose up db` para la base y corrés el backend localmente: DB_PORT=5433
# Si usás un Postgres local propio: DB_PORT=5432
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=borasi
DB_SSL=false

# JWT
JWT_SECRET=change-this-secret-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production-min-32-chars

# App
PORT=3000
FRONTEND_URL=http://localhost:3001

# AI (opcional)
ANTHROPIC_API_KEY=